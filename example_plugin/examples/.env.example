# ============================================
# LiveKit Ditto Avatar - Environment Variables
# ============================================

# ── LiveKit Configuration ──
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── AI Services ──
# LLM (choose one)
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key

# STT
DEEPGRAM_API_KEY=your-deepgram-api-key

# TTS (choose one)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
CARTESIA_API_KEY=your-cartesia-api-key

# ── Ditto Mode ──
# "local"   = SDK loaded in-process (requires GPU + ditto-talkinghead installed)
# "service" = HTTP calls to separate ditto-service (for Docker/K8s)
DITTO_MODE=local

# Ditto service URL (only used when DITTO_MODE=service)
DITTO_SERVICE_URL=http://localhost:8000

# ── Ditto Local Paths (only used when DITTO_MODE=local) ──
DITTO_PATH=../ditto-talkinghead
DITTO_DATA_ROOT=../ditto-talkinghead/checkpoints/ditto_pytorch
DITTO_CFG_PKL=../ditto-talkinghead/checkpoints/ditto_cfg/v0.4_hubert_cfg_pytorch.pkl
DITTO_SOURCE_IMAGE=../ditto-talkinghead/example/image.png

# ── HuggingFace (for downloading checkpoints) ──
HUGGINGFACE_TOKEN=your-huggingface-token

# ── Performance ──
# Number of agent workers (for multi-user scaling)
LIVEKIT_NUM_WORKERS=1
# Video resolution (256 for low-latency, 512 for high quality)
DITTO_VIDEO_WIDTH=512
DITTO_VIDEO_HEIGHT=512
DITTO_VIDEO_FPS=25
