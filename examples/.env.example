# =============================================================
#  ARTalk Examples — Local Dev/Test Environment
#  Copy this file to examples/.env and fill in your values.
#
#  This file takes priority over the project-root .env when
#  running scripts from the examples/ directory.
# =============================================================

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- ARTalk Server (GPU machine) ---
ARTALK_SERVER_URL=http://localhost:8000

# --- Avatar ---
# "mesh" = default neutral head.
# Use a replica_id from create_avatar_replica.py for a custom face.
ARTALK_REPLICA_ID=mesh

# --- AI Providers ---
OPENAI_API_KEY=your_openai_key
CARTESIA_API_KEY=your_cartesia_key
